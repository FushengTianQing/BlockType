// RUN: blocktype -ast-dump %s 2>&1 | FileCheck %s

// Test function template
template<typename T>
void swap(T& a, T& b) {
  T temp = a;
  a = b;
  b = temp;
}
// CHECK: FunctionTemplateDecl{{.*}}swap
// CHECK-NEXT: TemplateTypeParmDecl{{.*}}T

// Test class template (empty body to avoid template-param-as-type issue)
template<typename T>
class Vector {
};
// CHECK: ClassTemplateDecl{{.*}}Vector
// CHECK-NEXT: TemplateTypeParmDecl{{.*}}T

// Test variable template
template<typename T>
constexpr T pi = T(3.14159);
// CHECK: VarTemplateDecl{{.*}}pi
// CHECK-NEXT: TemplateTypeParmDecl{{.*}}T

// Test template with multiple parameters
template<typename K, typename V>
class Map {
};
// CHECK: ClassTemplateDecl{{.*}}Map
// CHECK-NEXT: TemplateTypeParmDecl{{.*}}K
// CHECK-NEXT: TemplateTypeParmDecl{{.*}}V

// Test variadic template
template<typename... Args>
void print(Args... args) {
}
// CHECK: FunctionTemplateDecl{{.*}}print
// CHECK-NEXT: TemplateTypeParmDecl{{.*}}Args{{.*}}parameter pack

// Test template specialization expression
Vector<int> v;
// CHECK: TemplateSpecializationExpr{{.*}}Vector
// CHECK-NEXT: Type: 'int'

// Test explicit template specialization (full specialization with concrete types)
template<>
class Vector<bool> {
  int count;
};
// CHECK: ClassTemplateSpecializationDecl{{.*}}Vector
// CHECK-NEXT: FieldDecl{{.*}}count

// Test function template specialization
template<>
void swap<double>(double& a, double& b) {
  a = b;
}
// CHECK: FunctionTemplateDecl{{.*}}swap
