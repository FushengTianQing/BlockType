// RUN: blocktype -ast-dump %s 2>&1 | FileCheck %s

// Test control flow statements
void testStmts() {
  // if statement
  if (true) {}
  // CHECK: IfStmt

  // while loop
  while (false) {}
  // CHECK: WhileStmt

  // for loop
  for (int i = 0; i < 10; ++i) {}
  // CHECK: ForStmt

  // return statement
  return;
  // CHECK: ReturnStmt
}
