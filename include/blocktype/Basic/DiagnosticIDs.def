//===----------------------------------------------------------------------===//
//
// This file defines diagnostic IDs for the BlockType compiler.
// Format: DIAG(ID, Level, EnglishText, ChineseText)
//
//===----------------------------------------------------------------------===//

#ifndef DIAG
#define DIAG(ID, Level, EnText, ZhText)
#endif

//===----------------------------------------------------------------------===//
// Lexer Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_lex_invalid_char, Error, \
  "invalid character in source code", \
  "源代码中存在无效字符")
DIAG(err_lex_invalid_identifier_start, Error, \
  "invalid Unicode character in identifier start", \
  "标识符起始位置存在无效的 Unicode 字符")
DIAG(err_lex_unterminated_char, Error, \
  "unterminated character constant", \
  "未终止的字符常量")
DIAG(err_lex_unterminated_string, Error, \
  "unterminated string literal", \
  "未终止的字符串字面量")
DIAG(err_lex_unterminated_raw_string, Error, \
  "unterminated raw string literal", \
  "未终止的原始字符串字面量")
DIAG(err_lex_invalid_raw_string, Error, \
  "invalid raw string literal delimiter", \
  "无效的原始字符串分隔符")
DIAG(err_lex_unterminated_block_comment, Error, \
  "unterminated block comment", \
  "未终止的块注释")
DIAG(err_lex_invalid_utf8, Error, \
  "invalid UTF-8 sequence", \
  "无效的 UTF-8 序列")

//===----------------------------------------------------------------------===//
// Preprocessor Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_pp_unexpected_eof, Error, \
  "unexpected end of file in preprocessor directive", \
  "预处理指令中意外的文件结束")
DIAG(err_pp_invalid_directive, Error, \
  "invalid preprocessor directive", \
  "无效的预处理指令")
DIAG(err_pp_expected_filename, Error, \
  "expected filename after #include", \
  "#include 后需要文件名")
DIAG(err_pp_expected_macro_name, Error, \
  "expected macro name", \
  "需要宏名称")
DIAG(err_pp_macro_not_identifier, Error, \
  "macro name must be an identifier", \
  "宏名称必须是标识符")
DIAG(err_pp_unterminated_macro_params, Error, \
  "unterminated macro parameter list", \
  "未终止的宏参数列表")
DIAG(err_pp_unterminated_macro_args, Error, \
  "unterminated macro argument list", \
  "未终止的宏参数列表")
DIAG(err_pp_file_not_found, Error, \
  "file not found", \
  "文件未找到")
DIAG(err_pp_cannot_read_file, Error, \
  "cannot read file", \
  "无法读取文件")
DIAG(err_pp_circular_include, Error, \
  "circular inclusion detected", \
  "检测到循环包含")
DIAG(err_pp_if_without_endif, Error, \
  "#if without #endif", \
  "#if 没有 matching #endif")
DIAG(err_pp_elif_without_if, Error, \
  "#elif without #if", \
  "#elif 没有匹配的 #if")
DIAG(err_pp_else_without_if, Error, \
  "#else without #if", \
  "#else 没有匹配的 #if")
DIAG(err_pp_endif_without_if, Error, \
  "#endif without #if", \
  "#endif 没有匹配的 #if")
DIAG(err_pp_duplicate_else, Error, \
  "duplicate #else", \
  "重复的 #else")
DIAG(err_pp_elif_after_else, Error, \
  "#elif after #else", \
  "#else 之后出现 #elif")

DIAG(warn_pp_include_not_implemented, Warning, \
  "#include not fully implemented", \
  "#include 未完全实现")
DIAG(warn_pp_embed_not_implemented, Warning, \
  "#embed not implemented yet", \
  "#embed 尚未实现")

DIAG(note_insert_semicolon, Note, \
  "did you forget a ';'?", \
  "是否遗漏了 ';'？")
DIAG(note_matching_paren, Note, \
  "to match this '('", \
  "匹配此 '('")
DIAG(note_matching_brace, Note, \
  "to match this '{'", \
  "匹配此 '{'")
DIAG(note_matching_square, Note, \
  "to match this '['", \
  "匹配此 '['")
DIAG(note_previous_declaration, Note, \
  "previous declaration starts here", \
  "前一个声明从这里开始")

DIAG(note_pp_macro_defined_here, Note, \
  "macro defined here", \
  "宏在此定义")

//===----------------------------------------------------------------------===//
// Parser Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_expected, Error, \
  "expected token", \
  "期望的 token")
DIAG(err_expected_semi, Error, \
  "expected ';' at end of statement", \
  "语句末尾期望 ';'")
DIAG(err_expected_lbrace, Error, \
  "expected '{'", \
  "期望 '{'")
DIAG(err_expected_rbrace, Error, \
  "expected '}'", \
  "期望 '}'")
DIAG(err_expected_lparen, Error, \
  "expected '('", \
  "期望 '('")
DIAG(err_expected_rparen, Error, \
  "expected ')'", \
  "期望 ')'")
DIAG(err_expected_colon, Error, \
  "expected ':'", \
  "期望 ':'")
DIAG(err_expected_identifier, Error, \
  "expected identifier", \
  "期望标识符")
DIAG(err_expected_type, Error, \
  "expected type name", \
  "期望类型名")
DIAG(err_expected_expression, Error, \
  "expected expression", \
  "期望表达式")
DIAG(err_expected_semi_or_decl, Error, \
  "expected ';' at end of declaration or a new declaration", \
  "期望 ';' 结束声明或新的声明")
DIAG(err_expected_token_and_got, Error, \
  "expected '%0' but got '%1'", \
  "期望 '%0' 但得到 '%1'")
DIAG(err_member_access_denied, Error, \
  "member '%0' is %1", \
  "成员 '%0' 是 %1，无法访问")
DIAG(err_expected_string_literal, Error, \
  "expected string literal", \
  "期望字符串字面量")
DIAG(err_expected_statement, Error, \
  "expected statement", \
  "期望语句")
DIAG(err_expected_declaration, Error, \
  "expected declaration", \
  "期望声明")
DIAG(err_unexpected_token, Error, \
  "unexpected token", \
  "意外的 token")
DIAG(err_invalid_operator, Error, \
  "invalid operator", \
  "无效的运算符")
DIAG(err_invalid_floating_literal, Error, \
  "invalid floating point literal '%0'", \
  "无效的浮点数字面量 '%0'")
DIAG(err_float_literal_overflow, Error, \
  "floating point literal '%0' overflows", \
  "浮点数字面量 '%0' 溢出")
DIAG(err_float_literal_underflow, Error, \
  "floating point literal '%0' underflows", \
  "浮点数字面量 '%0' 下溢")

//===----------------------------------------------------------------------===//
// General Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_unknown, Error, \
  "unknown error", \
  "未知错误")
DIAG(err_not_implemented, Error, \
  "feature not implemented", \
  "功能未实现")

//===----------------------------------------------------------------------===//
// Exception Handling Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_rethrow_not_in_catch, Error, \
  "rethrow not in catch handler", \
  "不在 catch 处理程序中的重新抛出")
DIAG(err_throw_incomplete_type, Error, \
  "cannot throw incomplete type", \
  "不能抛出不完整类型")
DIAG(err_throw_abstract_type, Error, \
  "cannot throw abstract class type", \
  "不能抛出抽象类类型")
DIAG(err_throw_non_copyable, Error, \
  "cannot throw non-copyable and non-movable type", \
  "不能抛出不可复制且不可移动的类型")
DIAG(err_throw_reference_type, Error, \
  "cannot throw reference type", \
  "不能抛出引用类型")
DIAG(err_throw_array_type, Error, \
  "cannot throw array type", \
  "不能抛出数组类型")
DIAG(err_throw_in_noexcept_function, Error, \
  "throw in noexcept function '%0'", \
  "noexcept 函数 '%0' 中出现 throw")
DIAG(warn_non_noexcept_call_in_noexcept, Warning, \
  "call to non-noexcept function '%0' in noexcept function", \
  "noexcept 函数中调用了非 noexcept 函数 '%0'")
DIAG(warn_unreachable_catch, Warning, \
  "catch clause is unreachable", \
  "catch 子句不可达")

//===----------------------------------------------------------------------===//
// Lambda Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_lambda_capture_odr_use, Error, \
  "variable '%0' is captured by reference but not odr-usable", \
  "变量 '%0' 被引用捕获但不可 ODR 使用")
DIAG(warn_lambda_capture_static, Warning, \
  "capturing static variable '%0' is unnecessary; it is always accessible", \
  "捕获静态变量 '%0' 是不必要的；它始终可访问")
DIAG(err_lambda_init_capture_deduction_failed, Error, \
  "cannot deduce type for init capture '%0'", \
  "无法推导初始化捕获 '%0' 的类型")
DIAG(err_lambda_generic_no_auto_param, Error, \
  "generic lambda requires at least one auto parameter", \
  "泛型 lambda 需要至少一个 auto 参数")

//===----------------------------------------------------------------------===//
// Implicit Conversion Diagnostics
//===----------------------------------------------------------------------===//

DIAG(err_no_user_defined_conversion, Error, \
  "no viable user-defined conversion from '%0' to '%1'", \
  "没有可行的用户定义转换从 '%0' 到 '%1'")
DIAG(err_derived_to_base_incomplete, Error, \
  "derived-to-base conversion with incomplete type", \
  "派生到基类转换中类型不完整")
DIAG(err_qual_conversion_incompatible, Error, \
  "qualification conversion between incompatible types", \
  "不兼容类型之间的限定符转换")
DIAG(err_array_to_pointer_incompatible, Error, \
  "array-to-pointer decay with incompatible element types", \
  "数组到指针衰减中元素类型不兼容")
